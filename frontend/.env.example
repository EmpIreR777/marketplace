# Vite base URL for API requests
VITE_BASE_URL=http://localhost:8000

# JivoChat widget key (optional)
VITE_JIVO_KEY=

# Google Tag Manager ID (optional)
VITE_GTM_ID=

# Yandex Metrika ID (optional)
VITE_YANDEX_METRIKA_ID=

# Docker nginx-proxy (for production deployment)
VIRTUAL_HOST=your-domain.com
LETSENCRYPT_HOST=your-domain.com
LETSENCRYPT_EMAIL=admin@domain.com
VIRTUAL_PORT=80